@model List<BookstoreWeb.Models.Order>

<h2 class="mb-4"><i class="bi bi-box-seam me-2"></i>My Orders</h2>

@if (!Model.Any())
{
    <!-- Trạng thái không có đơn hàng -->
    <div class="text-center py-5">
        <i class="bi bi-inbox text-muted" style="font-size: 4rem"></i>
        <h4 class="mt-3 text-muted">No orders yet</h4>
        <a asp-controller="Product" asp-action="Index" class="btn btn-primary mt-2">
            <i class="bi bi-arrow-left me-2"></i>Start Shopping
        </a>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card shadow-sm mb-4">
            <!-- Header: mã đơn, ngày, trạng thái với badge màu inline -->
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-bold">Order #@order.OrderID</span>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">@order.OrderDate?.ToString("dd/MM/yyyy")</span>
                    <span class="badge @(order.Status == "Completed" ? "bg-success" : order.Status == "Cancelled" ? "bg-danger" : order.Status == "Confirmed" ? "bg-primary" : "bg-secondary")">@order.Status</span>
                </div>
            </div>

            <div class="card-body">
                <!-- Danh sách sản phẩm trong đơn -->
                <table class="table table-sm mb-3">
                    <thead class="table-light">
                        <tr>
                            <th>Book</th>
                            <th style="width: 100px; text-align: center">Quantity</th>
                            <th style="width: 120px; text-align: right">Unit Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.OrderDetails)
                        {
                            <tr>
                                <td>@item.Product.Name</td>
                                <td style="text-align: center">@item.Quantity</td>
                                <td style="text-align: right">@item.UnitPrice.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Tổng tiền và nút hủy -->
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">
                        Total: <span class="text-danger">@order.TotalAmount?.ToString("C")</span>
                    </span>

                    <!-- Chỉ hiện nút Cancel nếu đơn chưa hoàn thành hoặc chưa bị hủy -->
                    @if (order.Status != "Completed" && order.Status != "Cancelled")
                    {
                        <form asp-action="CancelOrder" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="orderId" value="@order.OrderID" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-x-circle me-1"></i>Cancel Order
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
}
