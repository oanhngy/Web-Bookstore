@model BookstoreWeb.Models.Order

<!-- Thông báo đặt hàng thành công -->
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm text-center">
            <div class="card-body p-5">

                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem"></i>
                <h3 class="mt-3 fw-bold">Order Placed Successfully!</h3>
                <p class="text-muted">Thank you for your purchase.</p>

                <hr />

                <!-- Thông tin đơn hàng -->
                <div class="text-start">
                    <p><strong>Order #:</strong> @Model.OrderID</p>
                    <p><strong>Name:</strong> @Model.FullName</p>
                    <p><strong>Address:</strong> @Model.Address</p>
                    <p><strong>Payment:</strong> @Model.PaymentMethod</p>
                    <p class="fs-5"><strong>Total:</strong>
                        <span class="text-danger fw-bold">@Model.TotalAmount?.ToString("C")</span>
                    </p>
                </div>

                <hr />

                <div class="d-flex gap-3 justify-content-center mt-3">
                    <a asp-action="ViewOrderStatus" class="btn btn-outline-primary">
                        <i class="bi bi-box-seam me-2"></i>View My Orders
                    </a>
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-shop me-2"></i>Continue Shopping
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
