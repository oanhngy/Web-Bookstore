@model List<BookstoreWeb.Models.Order>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>Order Management</h2>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td class="fw-bold">#@order.OrderID</td>
                        <td>@order.OrderDate?.ToString("dd/MM/yyyy")</td>
                        <td class="fw-semibold">@order.TotalAmount?.ToString("C")</td>
                        <!-- Badge màu theo trạng thái, dùng inline ternary -->
                        <td><span class="badge @(order.Status == "Completed" ? "bg-success" : order.Status == "Cancelled" ? "bg-danger" : order.Status == "Confirmed" ? "bg-primary" : "bg-secondary")">@order.Status</span></td>
                        <td>
                            <div class="d-flex gap-2 align-items-center">
                                <a asp-action="Details" asp-route-orderId="@order.OrderID"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <!-- Form cập nhật trạng thái đơn hàng -->
                                <form asp-action="UpdateOrderStatus" method="post" class="d-flex gap-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="orderId" value="@order.OrderID" />
                                    <select name="status" class="form-select form-select-sm" style="width: 130px">
                                        <option value="Confirmed" selected="@(order.Status == "Confirmed")">Confirmed</option>
                                        <option value="Completed" selected="@(order.Status == "Completed")">Completed</option>
                                        <option value="Cancelled" selected="@(order.Status == "Cancelled")">Cancelled</option>
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-success">
                                        <i class="bi bi-check"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
