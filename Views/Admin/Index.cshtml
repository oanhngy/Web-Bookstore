@model List<BookstoreWeb.Models.Order>

<h2>Order Management</h2>

<table>
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Total</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderID</td>
                <td>@order.OrderDate?.ToString("dd/MM/yyyy")</td>
                <td>@order.TotalAmount?.ToString("C")</td>
                <td>@order.Status</td>
                <td>
                    <a asp-action="Details" asp-route-orderId="@order.OrderID">Details</a>

                    <form asp-action="UpdateOrderStatus" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@order.OrderID" />
                        <select name="status">
                            <option value="Confirmed" selected="@(order.Status == "Confirmed")">Confirmed</option>
                            <option value="Completed" selected="@(order.Status == "Completed")">Completed</option>
                            <option value="Cancelled" selected="@(order.Status == "Cancelled")">Cancelled</option>
                        </select>
                        <button type="submit">Update</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>