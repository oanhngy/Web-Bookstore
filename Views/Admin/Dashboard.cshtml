<!-- Stats cards -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h2>
    <div class="d-flex gap-2">
        <a asp-action="ProductList" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-box me-1"></i>Products
        </a>
        <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-tags me-1"></i>Categories
        </a>
        <a asp-action="Index" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-receipt me-1"></i>Orders
        </a>
        <a asp-action="ViewRevenue" class="btn btn-outline-success btn-sm">
            <i class="bi bi-bar-chart me-1"></i>Revenue
        </a>
    </div>
</div>

<!-- Thống kê tổng quan -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small">Total Products</div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalProducts</div>
                </div>
                <i class="bi bi-book" style="font-size: 2.5rem; opacity: 0.6"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small">New Orders Today</div>
                    <div class="fs-3 fw-bold">@ViewBag.NewOrders</div>
                </div>
                <i class="bi bi-bag" style="font-size: 2.5rem; opacity: 0.6"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="small">Today Revenue</div>
                    <div class="fs-3 fw-bold">@string.Format("{0:C}", ViewBag.TodayRevenue)</div>
                </div>
                <i class="bi bi-cash-coin" style="font-size: 2.5rem; opacity: 0.6"></i>
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng gần đây -->
<div class="card shadow-sm">
    <div class="card-header fw-bold">
        <i class="bi bi-clock-history me-2"></i>Recent Orders
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Total</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in ViewBag.RecentOrders)
                {
                    <tr>
                        <td>#@order.OrderID</td>
                        <td class="fw-semibold text-success">@string.Format("{0:C}", order.TotalAmount)</td>
                        <td>@string.Format("{0:dd/MM/yyyy}", order.OrderDate)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
