@model BookstoreWeb.Models.Product

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Add Product</h2>
    <div class="d-flex gap-2">
        <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-speedometer2 me-1"></i>Dashboard
        </a>
        <a asp-action="ProductList" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Product List
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <form asp-action="AddProduct" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Tên sách -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <!-- Tác giả -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Author</label>
                <input asp-for="Author" class="form-control" />
            </div>

            <!-- Mô tả -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <!-- Giá -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Price</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" required />
            </div>

            <!-- Danh mục -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Category</label>
                <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-select"></select>
            </div>

            <!-- Upload ảnh với chọn primary -->
            <div class="mb-4">
                <label class="form-label fw-semibold">Images</label>
                <p class="text-muted small mb-2">Select the radio button next to the image you want as primary.</p>

                <!-- Hàng ảnh 1 — index 0, mặc định là primary -->
                <div class="d-flex align-items-center gap-3 mb-2 p-2 border rounded">
                    <input type="radio" name="primaryIndex" value="0" checked class="form-check-input mt-0" />
                    <label class="form-check-label text-success fw-semibold">Primary</label>
                    <input type="file" name="ImageFiles" class="form-control" />
                </div>

                <!-- Hàng ảnh 2 — index 1 -->
                <div class="d-flex align-items-center gap-3 mb-2 p-2 border rounded">
                    <input type="radio" name="primaryIndex" value="1" class="form-check-input mt-0" />
                    <label class="form-check-label text-success fw-semibold">Primary</label>
                    <input type="file" name="ImageFiles" class="form-control" />
                </div>

                <!-- Hàng ảnh 3 — index 2 -->
                <div class="d-flex align-items-center gap-3 mb-2 p-2 border rounded">
                    <input type="radio" name="primaryIndex" value="2" class="form-check-input mt-0" />
                    <label class="form-check-label text-success fw-semibold">Primary</label>
                    <input type="file" name="ImageFiles" class="form-control" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-check-lg me-2"></i>Add Product
            </button>
        </form>
    </div>
</div>
