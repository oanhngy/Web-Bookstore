@model BookstoreWeb.Models.Product

<h2>Add Product</h2>

<form asp-action="AddProduct" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div>
        <label>Name</label>
        <input asp-for="Name" required />
    </div>
    <div>
        <label>Author</label>
        <input asp-for="Author" />
    </div>
    <div>
        <label>Description</label>
        <textarea asp-for="Description"></textarea>
    </div>
    <div>
        <label>Price</label>
        <input asp-for="Price" type="number" step="0.01" required />
    </div>
    <div>
        <label>Category</label>
        <select asp-for="CategoryID" asp-items="ViewBag.Categories"></select>
    </div>
    <div>
        <label>Images</label>
        <!-- Hàng ảnh 1: radio value =0, default được chọn -->
        <div>
            <input type="radio" name="primaryIndex" value="0" checked/>
            <label>Primary</label>
            <input type="file" name="ImageFiles" />
        </div>

        <!-- Hàng 2 -->
        <div>
            <input type="radio" name="primaryIndex" value="0" checked/>
            <label>Primary</label>
            <input type="file" name="ImageFiles" />
        </div>

        <!-- Hàng 3 -->
        <div>
            <input type="radio" name="primaryIndex" value="0" checked/>
            <label>Primary</label>
            <input type="file" name="ImageFiles" />
        </div>
    </div>

    <button type="submit">Add Product</button>
</form>

<a asp-action="ProductList">Back to list</a>