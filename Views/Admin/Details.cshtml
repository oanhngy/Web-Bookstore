@model BookstoreWeb.Models.Order

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-receipt me-2"></i>Order #@Model.OrderID</h2>
    <div class="d-flex gap-2">
        <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-speedometer2 me-1"></i>Dashboard
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Orders
        </a>
    </div>
</div>

<div class="row g-4">

    <!-- Thông tin khách hàng -->
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-bold">
                <i class="bi bi-person me-2"></i>Customer Info
            </div>
            <div class="card-body">
                @{
                    string badgeClass;
                    if (Model.Status == "Completed") badgeClass = "bg-success";
                    else if (Model.Status == "Cancelled") badgeClass = "bg-danger";
                    else if (Model.Status == "Confirmed") badgeClass = "bg-primary";
                    else if (Model.Status == "Checked Out") badgeClass = "bg-warning text-dark";
                    else badgeClass = "bg-secondary";
                }
                <p><strong>Status:</strong> <span class="badge @badgeClass">@Model.Status</span></p>
                <p><strong>Date:</strong> @Model.OrderDate?.ToString("dd/MM/yyyy")</p>
                <p><strong>Name:</strong> @Model.FullName</p>
                <p><strong>Email:</strong> @Model.Email</p>
                <p><strong>Phone:</strong> @Model.Phone</p>
                <p><strong>Address:</strong> @Model.Address</p>
                <p class="mb-0"><strong>Payment:</strong> @Model.PaymentMethod</p>
            </div>
        </div>
    </div>

    <!-- Danh sách sản phẩm trong đơn -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header fw-bold">
                <i class="bi bi-bag me-2"></i>Order Items
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Book</th>
                            <th style="text-align: center">Qty</th>
                            <th style="text-align: right">Unit Price</th>
                            <th style="text-align: right">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td>@item.Product.Name</td>
                                <td style="text-align: center">@item.Quantity</td>
                                <td style="text-align: right">@item.UnitPrice.ToString("C")</td>
                                <td style="text-align: right" class="fw-semibold">
                                    @((item.Quantity * item.UnitPrice).ToString("C"))
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer d-flex justify-content-between">
                <span class="fw-bold">Total</span>
                <span class="fw-bold text-danger fs-5">@Model.TotalAmount?.ToString("C")</span>
            </div>
        </div>
    </div>

</div>
