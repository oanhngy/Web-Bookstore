@model BookstoreWeb.Models.Order

<h2>Order #@Model.OrderID</h2>

<p>Status: @Model.Status</p>
<p>Date: @Model.OrderDate?.ToString("dd/MM/yyyy")</p>
<p>Customer: @Model.FullName</p>
<p>Email: @Model.Email</p>
<p>Phone: @Model.Phone</p>
<p>Address: @Model.Address</p>
<p>Payment: @Model.PaymentMethod</p>

<h4>Items</h4>
<table>
    <thead>
        <tr>
            <th>Book</th>
            <th>Quantity</th>
            <th>Unit Price</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.OrderDetails)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice.ToString("C")</td>
                <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
            </tr>
        }
    </tbody>
</table>

<p><strong>Total: @Model.TotalAmount?.ToString("C")</strong></p>

<a asp-action="Index">Back to Orders</a>