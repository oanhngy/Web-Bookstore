@model List<BookstoreWeb.Models.Product>

<h2>Product List</h2>

<a asp-action="AddProduct">Add New Product</a>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Author</th>
            <th>Category</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Name</td>
                <td>@product.Author</td>
                <td>@product.Category?.Name</td>
                <td>@product.Price.ToString("C")</td>
                <td>
                    <a asp-action="EditProduct" asp-route-id="@product.ProductID">Edit</a>

                    <form asp-action="DeleteProduct" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@product.ProductID" />
                        <button type="submit" onclick="return confirm('Delete this product?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>