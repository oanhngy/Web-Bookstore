<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Revenue Report</h2>
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Dashboard
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">

        <!-- Dropdown chọn khung thời gian -->
        <div class="mb-4">
            <select id="timeFrame" class="form-select" style="width: 200px">
                <option value="day">By Day</option>
                <option value="week">By Week</option>
                <option value="month">By Month</option>
                <option value="year">By Year</option>
            </select>
        </div>

        <!-- Biểu đồ doanh thu -->
        <canvas id="revenueChart"></canvas>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Tạo biểu đồ cột rỗng ban đầu
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: [],
                datasets: [{
                    label: 'Revenue',
                    data: [],
                    backgroundColor: 'rgba(13, 110, 253, 0.7)',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Gọi API lấy data và cập nhật biểu đồ
        function loadChart(timeFrame) {
            fetch(`/Admin/GetRevenueData?timeFrame=${timeFrame}`)
                .then(res => res.json())
                .then(data => {
                    chart.data.labels = data.map(d => d.label);
                    chart.data.datasets[0].data = data.map(d => d.totalRevenue);
                    chart.update();
                });
        }

        // Load mặc định và xử lý đổi timeframe
        loadChart('day');
        document.getElementById('timeFrame').addEventListener('change', e => loadChart(e.target.value));
    </script>
}
