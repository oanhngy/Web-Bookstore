@model X.PagedList.IPagedList<BookstoreWeb.Models.Product>
@using X.PagedList.Mvc.Core

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-journal-bookmark me-2"></i>Books</h2>

    <!-- Search form -->
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <input type="text" name="searchString" value="@ViewBag.SearchString"
               placeholder="Search books..." class="form-control" style="width: 250px" />
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-search"></i>
        </button>
    </form>
</div>

<!-- Danh sách sách hiển thị dạng lưới 4 cột -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4 mb-4">
    @foreach (var product in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">

                <!-- Ảnh bìa sách -->
                @{
                    var primaryImage = product.ProductImages?
                        .FirstOrDefault(img => img.IsPrimary == true && img.ImageType == "main");
                }
                @if (primaryImage != null)
                {
                    <!-- Bọc ảnh trong div vuông, object-fit cover để ảnh lấp đầy không bị méo -->
                    <div style="width: 100%; aspect-ratio: 1/1; overflow: hidden;">
                        <img src="~/images/@primaryImage.ImagePath"
                             style="width: 100%; height: 100%; object-fit: cover;"
                             alt="@product.Name" />
                    </div>
                }
                else
                {
                    <!-- Placeholder vuông nếu không có ảnh -->
                    <div class="bg-secondary d-flex align-items-center justify-content-center"
                         style="width: 100%; aspect-ratio: 1/1;">
                        <i class="bi bi-book text-white" style="font-size: 3rem"></i>
                    </div>
                }

                <!-- Thông tin sách -->
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold">@product.Name</h6>
                    <p class="card-text text-muted small mb-1">@product.Author</p>
                    <p class="card-text text-muted small mb-2">
                        <i class="bi bi-tag me-1"></i>@product.Category?.Name
                    </p>
                    <p class="card-text fw-bold text-danger mt-auto">
                        @product.Price.ToString("C")
                    </p>
                    <a asp-action="Details" asp-route-id="@product.ProductID"
                       class="btn btn-outline-primary btn-sm">
                        View Details
                    </a>
                </div>

            </div>
        </div>
    }
</div>

<!-- Pagination -->
<div class="d-flex justify-content-center">
    @Html.PagedListPager(Model, page => Url.Action("Index", new {
        page,
        sortOrder = ViewBag.CurrentSort,
        searchString = ViewBag.SearchString,
        category = ViewBag.Category
    }), new X.PagedList.Mvc.Core.PagedListRenderOptions
    {
        LiElementClasses = new[] { "page-item" },
        PageClasses = new[] { "page-link" },
        UlElementClasses = new[] { "pagination" }
    })
</div>
