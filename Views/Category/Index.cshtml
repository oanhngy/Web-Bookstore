@model List<BookstoreWeb.Models.Category>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0"><i class="bi bi-tags me-2"></i>Categories</h2>
    <div class="d-flex gap-2">
        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Dashboard
        </a>
        <a asp-action="AddCategory" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Add Category
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px">ID</th>
                    <th>Name</th>
                    <th style="text-align: center; width: 150px">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Hiển thị danh sách category -->
                @foreach (var category in Model)
                {
                    <tr>
                        <td class="text-muted">@category.CategoryID</td>
                        <td class="fw-semibold">@category.Name</td>
                        <td style="text-align: center">
                            <a asp-action="EditCategory" asp-route-id="@category.CategoryID"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>

                            <!-- Form xóa category -->
                            <form asp-action="DeleteCategory" method="post" style="display:inline">
                                <input type="hidden" name="id" value="@category.CategoryID" />
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('Delete this category?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
