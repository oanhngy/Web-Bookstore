@model BookstoreWeb.Models.Category

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title mb-4">
                    <i class="bi bi-pencil me-2"></i>Edit Category
                </h3>

                <div asp-validation-summary="All" class="alert alert-danger mb-3"></div>

                <form asp-action="EditCategory" method="post">
                    <!-- Giữ ID ẩn để biết đang sửa category nào -->
                    <input type="hidden" asp-for="CategoryID" />

                    <!-- Tên category -->
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Category Name</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Save
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
