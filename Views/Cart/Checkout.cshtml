@model BookstoreWeb.Models.Order

<h2>Checkout</h2>

<!-- Order summary -->
<h4>Order Summary</h4>
@foreach (var item in Model.OrderDetails)
{
    <p>@item.Product.Name x@item.Quantity — @((item.Quantity * item.UnitPrice).ToString("C"))</p>
}
<p><strong>Total: @Model.TotalAmount?.ToString("C")</strong></p>

<hr />

<!-- Delivery info form -->
<form asp-controller="Order" asp-action="ConfirmOrder" method="post">
    @Html.AntiForgeryToken()

    <div>
        <label>Full Name</label>
        <input type="text" name="FullName" required />
    </div>
    <div>
        <label>Email</label>
        <input type="email" name="Email" required />
    </div>
    <div>
        <label>Phone</label>
        <input type="text" name="Phone" required />
    </div>
    <div>
        <label>Address</label>
        <input type="text" name="Address" required />
    </div>
    <div>
        <label>Note</label>
        <input type="text" name="Note" />
    </div>
    <div>
        <label>Payment Method</label>
        <select name="PaymentMethod">
            <option value="COD">Cash on Delivery</option>
            <option value="Banking">Bank Transfer</option>
        </select>
    </div>

    <button type="submit">Place Order</button>
</form>
