@model BookstoreWeb.Models.Order

<h2 class="mb-4"><i class="bi bi-bag-check me-2"></i>Checkout</h2>

<div class="row g-4">

    <!-- Cột trái: Form thông tin giao hàng -->
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">
                    <i class="bi bi-truck me-2"></i>Delivery Information
                </h5>

                <form asp-controller="Order" asp-action="ConfirmOrder" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Họ tên -->
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" name="FullName" class="form-control" required />
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" class="form-control" required />
                    </div>

                    <!-- Số điện thoại -->
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input type="text" name="Phone" class="form-control" required />
                    </div>

                    <!-- Địa chỉ -->
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <input type="text" name="Address" class="form-control" required />
                    </div>

                    <!-- Ghi chú -->
                    <div class="mb-3">
                        <label class="form-label">Note</label>
                        <textarea name="Note" class="form-control" rows="2"></textarea>
                    </div>

                    <!-- Phương thức thanh toán -->
                    <div class="mb-4">
                        <label class="form-label">Payment Method</label>
                        <select name="PaymentMethod" class="form-select">
                            <option value="COD">Cash on Delivery</option>
                            <option value="Banking">Bank Transfer</option>
                        </select>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2">
                        <i class="bi bi-check-circle me-2"></i>Place Order
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Cột phải: Tóm tắt đơn hàng -->
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h5 class="card-title mb-4">
                    <i class="bi bi-receipt me-2"></i>Order Summary
                </h5>

                <!-- Danh sách sản phẩm -->
                @foreach (var item in Model.OrderDetails)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>@item.Product.Name <span class="text-muted">x@item.Quantity</span></span>
                        <span class="fw-semibold">@((item.Quantity * item.UnitPrice).ToString("C"))</span>
                    </div>
                }

                <hr />

                <!-- Tổng tiền -->
                <div class="d-flex justify-content-between">
                    <span class="fw-bold fs-5">Total</span>
                    <span class="fw-bold fs-5 text-danger">@Model.TotalAmount?.ToString("C")</span>
                </div>
            </div>
        </div>
    </div>

</div>
