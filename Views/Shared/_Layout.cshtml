<!--là khung HTML dùng chung gồm navbar, footer, vùng RenderBody() nội dung từng View nhúng vào-->

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bookstore</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">

            <!-- Logo / tên trang -->
            <a class="navbar-brand fw-bold" asp-controller="Product" asp-action="Index">
                <i class="bi bi-book-half me-2"></i>Bookstore
            </a>

            <!-- Nút hamburger cho mobile -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Các link trong navbar -->
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto">

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <!-- Admin: chỉ hiện link Dashboard và Logout -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>
                        }
                        else
                        {
                            <!-- Customer: hiện Cart và Orders -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cart" asp-action="ViewCart">
                                    <i class="bi bi-cart3 me-1"></i>Cart
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Order" asp-action="ViewOrderStatus">
                                    <i class="bi bi-box-seam me-1"></i>Orders
                                </a>
                            </li>
                        }

                        <!-- Nút đăng xuất cho tất cả -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </a>
                        </li>
                    }
                    else
                    {
                        <!-- Nút đăng nhập -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person me-1"></i>Login
                            </a>
                        </li>

                        <!-- Nút đăng ký -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Register
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    <!-- Nội dung chính -->
    <div class="container">

        <!-- Hiển thị thông báo thành công nếu có -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Nội dung từng View render ở đây -->
        @RenderBody()

    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Cho phép các View inject thêm script riêng nếu cần -->
    @RenderSection("Scripts", required: false)

</body>
</html>
